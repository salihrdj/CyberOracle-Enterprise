# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/cyber_enterprise

# JWT Secret - Generate with: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_here

# JWT Key Rotation (optional) - JSON dict of key_id -> secret_key
# Current key is the first one; previous keys kept for validation during rotation
# Example: JWT_KEYS={"key-1": "secret1", "key-2": "secret2"}
# JWT_CURRENT_KEY_ID=key-1
# JWT_KEYS=
# JWT_CURRENT_KEY_ID=

# Initial Admin Password (optional) - Set to create admin user on first run
# Generate with: openssl rand -base64 16
INIT_ADMIN_PASSWORD=

# AI Provider (groq, gemini, claude)
AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=
CLAUDE_API_KEY=

# n8n Webhook URL for SOAR automation
N8N_WEBHOOK_URL=http://localhost:5678/webhook/threat-alert

# SMTP Configuration for Direct Email Alerts
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_RECIPIENT_EMAIL=your-destination-email@gmail.com

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Allow scanning internal/private networks (default: false in cloud)
ALLOW_INTERNAL_SCANS=false

# Scan concurrency limit
SCAN_CONCURRENCY=50

# Maximum CIDR prefix length (larger number = smaller network)
MAX_CIDR_PREFIXLEN=24

# Maximum hosts per scan
MAX_HOSTS_PER_SCAN=256

# Allowed scan networks (comma-separated CIDRs) - if set, only these networks can be scanned
ALLOWED_SCAN_NETWORKS=

# Explicitly denied scan networks (comma-separated CIDRs)
DENIED_SCAN_NETWORKS=

# Alembic Migration Configuration
# Run migrations with: python scripts/init_alembic.py
# Or manually: alembic upgrade head